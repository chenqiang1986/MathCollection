# Environment for the Docker containers (docker_run.sh / docker_run_worker.sh).
# Same as .env, except DATABASE_URL points at the host instead of localhost:
# inside a container, localhost is the container itself, so use
# host.docker.internal — Docker Desktop's alias for the Mac host.
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_CLIENT_ID=SOME_CLIENT_ID
GOOGLE_CLIENT_SECRET=SOME_CLIENT_SECRET
CLAUDE_CODE_USE_OAUTH=1
DATABASE_URL=postgresql://postgres:PASSWORD@host.docker.internal:5432/postgres
PG_SCHEMA=math_collection
